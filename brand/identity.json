{
  "brand": {
    "name": "Simply Us & U",
    "tagline": "Your Growth. Our Obsession.",
    "url": "https://www.simplyusandu.com",
    "industry": "Digital Marketing & Software Agency",
    "target_market": "Small to mid-sized businesses seeking growth",
    "value_proposition": "Big-agency results without the big-agency price tag",
    "founding_year": 2017
  },
  "colors": {
    "primary_background": "#0B0B0D",
    "primary_text": "#FFFFFF",
    "secondary_text": "#9CA3AF",
    "accent": "#F97316",
    "accent_name": "Orange",
    "border_subtle": "rgba(255, 255, 255, 0.06)",
    "dark_mode": true,
    "palette": [
      {
        "name": "Obsidian (Background)",
        "hex": "#0B0B0D",
        "usage": "Primary page background, cards, footer"
      },
      {
        "name": "White (Primary Text)",
        "hex": "#FFFFFF",
        "usage": "Headings, body text, nav links, CTA labels"
      },
      {
        "name": "Slate Gray (Secondary Text)",
        "hex": "#9CA3AF",
        "usage": "Subheadings, descriptions, muted labels, meta text"
      },
      {
        "name": "Vivid Orange (Accent / Brand)",
        "hex": "#F97316",
        "usage": "Section eyebrows, icon accents, CTA highlights, stat labels, numbered steps"
      },
      {
        "name": "White Ghost (Border)",
        "hex": "rgba(255,255,255,0.06)",
        "usage": "Dividers, card borders, section separators"
      }
    ]
  },
  "typography": {
    "primary_font": "Plus Jakarta Sans",
    "primary_font_type": "Variable",
    "secondary_font": "Inter",
    "secondary_font_type": "Variable",
    "css_variable": "--font-inter",
    "fallback_stack": "system-ui, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'",
    "hierarchy": {
      "display": { "font": "Plus Jakarta Sans", "weight": "700-800", "notes": "Hero headline, section titles" },
      "heading": { "font": "Plus Jakarta Sans", "weight": "600-700", "notes": "Service titles, testimonial names" },
      "subheading": { "font": "Inter", "weight": "500-600", "notes": "Section eyebrows, card subtitles (often uppercase)" },
      "body": { "font": "Inter", "weight": "400", "notes": "Descriptions, feature lists, footer text" },
      "label": { "font": "Inter", "weight": "600", "notes": "Stats, numbered steps — often uppercase tracking-widest" }
    }
  },
  "logo": {
    "primary": "/logo-transparent.png",
    "next_optimized": "/_next/image?url=%2Flogo-transparent.png&w=3840&q=75",
    "favicon": "/favicon.ico",
    "background": "Transparent (works on dark background)"
